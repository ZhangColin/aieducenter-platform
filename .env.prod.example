# 生产环境变量配置模板
# 使用方式：
#   1. 复制此文件为 .env.prod
#   2. 填写实际的生产环境配置
#   3. 确保 .env.prod 在 .gitignore 中

# ============ 数据库配置 ============
# PostgreSQL 云服务连接信息
SPRING_DATASOURCE_URL=jdbc:postgresql://your-production-db-host:5432/aieducenter
SPRING_DATASOURCE_USERNAME=aiedu
SPRING_DATASOURCE_PASSWORD=your-secure-password

# ============ Redis 配置 ============
REDIS_HOST=your-redis-host-or-ip
REDIS_PORT=6379

# ============ 前端配置 ============
# 前端访问后端 API 的地址
NEXT_PUBLIC_API_URL=https://api.your-domain.com

# ============ 端口配置 ============
# 服务端口（可选，默认值见 docker-compose.prod.yml）
BACKEND_PORT=8080
WEB_PORT=3000
ADMIN_PORT=3001
